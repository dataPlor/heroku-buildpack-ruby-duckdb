#!/bin/bash
# bin/compile <build-dir> <cache-dir> <env-dir>

# Fail fast and treat unset variables as errors
set -euo pipefail

header() {
  echo "" || true
  echo "-----> $*" || true
}

indent() {
  sed -u 's/^/       /'
}

# Parse params
BUILD_DIR=$1
CACHE_DIR=$2
ENV_DIR=$3
LP_DIR=$(cd $(dirname $0); cd ..; pwd)

VENDOR_DIR="$BUILD_DIR/vendor"
DUCKDB_VERSION="1.4.1"
CACHE_FILE="$CACHE_DIR/duckdb-$DUCKDB_VERSION.tar.gz"
DUCKDB_DIR="$BUILD_DIR/vendor/duckdb"

# Expected SHA256 (verify this from official DuckDB releases)
EXPECTED_SHA256="ce859962fe96ca952d53571964dafa0168644283a76a2c669b3f73120d710edb"

header "Installing DuckDB v$DUCKDB_VERSION"

if [ ! -f "$CACHE_FILE" ]; then
  echo "[duckdb-buildpack] Installing DuckDB from source" | indent
  
  mkdir -p "$DUCKDB_DIR/lib"
  mkdir -p "$DUCKDB_DIR/include"
  mkdir -p "$CACHE_DIR"

  # Download DuckDB C++ package
  ZIP_FILE="libduckdb-linux-amd64.zip"
  DUCKDB_PACKAGE_URL="https://github.com/duckdb/duckdb/releases/download/v$DUCKDB_VERSION/$ZIP_FILE"
  
  header "Downloading DuckDB from $DUCKDB_PACKAGE_URL"
  
  # Use secure download with retry and timeout
  if ! curl -fsSL --retry 3 --retry-delay 2 --max-time 300 \
       "$DUCKDB_PACKAGE_URL" -o "$ZIP_FILE"; then
    echo "ERROR: Failed to download DuckDB" >&2
    exit 1
  fi

  # Verify checksum BEFORE extraction
  header "Verifying SHA256 checksum"
  ACTUAL_SHA256=$(sha256sum "$ZIP_FILE" | awk '{print $1}')
  
  if [ "$ACTUAL_SHA256" != "$EXPECTED_SHA256" ]; then
    echo "ERROR: SHA256 mismatch!" >&2
    echo "  Expected: $EXPECTED_SHA256" >&2
    echo "  Got:      $ACTUAL_SHA256" >&2
    rm -f "$ZIP_FILE"
    exit 1
  fi
  
  echo "Checksum verified successfully" | indent

  # Extract DuckDB files
  header "Extracting DuckDB"
  if ! unzip -q "$ZIP_FILE" -d libduckdb; then
    echo "ERROR: Failed to extract DuckDB archive" >&2
    rm -f "$ZIP_FILE"
    exit 1
  fi
  
  # Copy files with error checking
  if [ ! -f "libduckdb/libduckdb.so" ]; then
    echo "ERROR: libduckdb.so not found in archive" >&2
    exit 1
  fi
  
  cp libduckdb/libduckdb.so "$DUCKDB_DIR/lib/"
  cp libduckdb/duckdb.* "$DUCKDB_DIR/include/"
  
  # Clean up temporary files
  rm -rf libduckdb "$ZIP_FILE"

  # Cache for future deploys
  header "Caching DuckDB installation"
  cd "$VENDOR_DIR"
  tar czf "$CACHE_FILE" duckdb
  
  echo "DuckDB cached successfully" | indent
else
  # Cache exists, extract it
  header "Extracting cached DuckDB from $CACHE_FILE"
  mkdir -p "$VENDOR_DIR"
  
  if ! tar xzf "$CACHE_FILE" -C "$VENDOR_DIR"; then
    echo "ERROR: Failed to extract cached DuckDB, removing cache" >&2
    rm -f "$CACHE_FILE"
    exit 1
  fi
fi

# Install to runtime location
ACTUAL_INSTALL_PATH="$HOME/vendor/duckdb"
mkdir -p "$ACTUAL_INSTALL_PATH/lib"
mkdir -p "$ACTUAL_INSTALL_PATH/include"

cp -r "$DUCKDB_DIR/lib/"* "$ACTUAL_INSTALL_PATH/lib/"
cp -r "$DUCKDB_DIR/include/"* "$ACTUAL_INSTALL_PATH/include/"

# Verify installation
if [ ! -f "$ACTUAL_INSTALL_PATH/lib/libduckdb.so" ]; then
  echo "ERROR: DuckDB installation verification failed" >&2
  exit 1
fi

header "DuckDB installation complete"
echo "Location: $ACTUAL_INSTALL_PATH" | indent